<?xml version="1.0"?>
<launch>
  <arg name="eap_lidar_topic" default="/eap/lidar/points"/>
  <arg name="use_spot_sdk" default="true"/>
  <arg name="spot_ip" default="$(env SPOT_IP '')"/>
  <arg name="spot_pointcloud_service" default="velodyne-point-cloud"/>
  <arg name="spot_pointcloud_source" default=""/>
  <arg name="spot_publish_rate" default="10.0"/>
  <arg name="spot_downsample_rate" default="1"/>
  <arg name="spot_rpc_timeout_sec" default="5.0"/>
  <arg name="spot_reconnect_interval_sec" default="5.0"/>
  <arg name="lidar_frame" default="lidar"/>
  <arg name="camera_frame" default="camera_optical_frame"/>
  <arg name="camera_index" default="0"/>
  <arg name="camera_frame_rate" default="30.0"/>
  <arg name="camera_reconnect_interval_sec" default="2.0"/>
  <arg name="publish_camera" default="true"/>
  <arg name="image_monitor" default="false"/>
  <arg name="pointcloud_monitor" default="true"/>
  <arg name="publish_extrinsics" default="false"/>
  <arg name="timestamp_mode" default="source"/>
  <arg name="max_cloud_age_sec" default="0.5"/>
  <arg name="max_future_offset_sec" default="0.05"/>
  <arg name="detector" default="false"/>
  <arg name="dataset_path"
       default="$(find-pkg-share defect_detection)/models/dataset.yaml"/>
  <arg name="model_path"
       default="$(find-pkg-share defect_detection)/models/yolov11m.engine"/>
  <arg name="fusion" default="false"/>
  <arg name="calibration_path"
       default="$(find-pkg-share defect_detection)/config/site_calibration.yaml"/>
  <arg name="visualization" default="true"/>
  <arg name="rviz" default="false"/>
  <arg name="visualization_pointcloud_topic" default="/rviz/pointcloud"/>
  <arg name="markers_topic" default="/detection_markers"/>
  <arg name="box_alpha" default="0.30"/>
  <arg name="label_height" default="0.15"/>
  <arg name="marker_lifetime_sec" default="0.50"/>
  <arg name="sync_queue_size" default="30"/>
  <arg name="sync_slop_sec" default="0.10"/>

  <node if="$(var use_spot_sdk)"
        pkg="spot_eap_bridge"
        exec="spot_sdk_pointcloud"
        name="spot_sdk_pointcloud"
        output="screen">
    <param name="hostname" value="$(var spot_ip)"/>
    <param name="service_name" value="$(var spot_pointcloud_service)"/>
    <param name="source_name" value="$(var spot_pointcloud_source)"/>
    <param name="output_topic" value="$(var eap_lidar_topic)"/>
    <param name="publish_rate" value="$(var spot_publish_rate)"/>
    <param name="downsample_rate" value="$(var spot_downsample_rate)"/>
    <param name="rpc_timeout_sec" value="$(var spot_rpc_timeout_sec)"/>
    <param name="reconnect_interval_sec"
           value="$(var spot_reconnect_interval_sec)"/>
  </node>

  <include file="$(find-pkg-share spot_eap_bridge)/launch/spot_eap_bridge.launch.xml">
    <arg name="input_topic" value="$(var eap_lidar_topic)"/>
    <arg name="lidar_frame" value="$(var lidar_frame)"/>
    <arg name="camera_frame" value="$(var camera_frame)"/>
    <arg name="publish_extrinsics" value="$(var publish_extrinsics)"/>
    <arg name="timestamp_mode" value="$(var timestamp_mode)"/>
    <arg name="max_cloud_age_sec" value="$(var max_cloud_age_sec)"/>
    <arg name="max_future_offset_sec" value="$(var max_future_offset_sec)"/>
  </include>

  <include file="$(find-pkg-share defect_detection)/launch/defect_detection.launch.xml">
    <arg name="publish_camera" value="$(var publish_camera)"/>
    <arg name="camera_index" value="$(var camera_index)"/>
    <arg name="camera_frame" value="$(var camera_frame)"/>
    <arg name="camera_frame_rate" value="$(var camera_frame_rate)"/>
    <arg name="camera_reconnect_interval_sec"
         value="$(var camera_reconnect_interval_sec)"/>
    <arg name="image_monitor" value="$(var image_monitor)"/>
    <arg name="pointcloud_monitor" value="$(var pointcloud_monitor)"/>
    <arg name="detector" value="$(var detector)"/>
    <arg name="dataset_path" value="$(var dataset_path)"/>
    <arg name="model_path" value="$(var model_path)"/>
    <arg name="fusion" value="$(var fusion)"/>
    <arg name="calibration_path" value="$(var calibration_path)"/>
    <arg name="visualization" value="$(var visualization)"/>
    <arg name="rviz" value="$(var rviz)"/>
    <arg name="visualization_pointcloud_topic"
         value="$(var visualization_pointcloud_topic)"/>
    <arg name="markers_topic" value="$(var markers_topic)"/>
    <arg name="box_alpha" value="$(var box_alpha)"/>
    <arg name="label_height" value="$(var label_height)"/>
    <arg name="marker_lifetime_sec" value="$(var marker_lifetime_sec)"/>
    <arg name="sync_queue_size" value="$(var sync_queue_size)"/>
    <arg name="sync_slop_sec" value="$(var sync_slop_sec)"/>
  </include>
</launch>
