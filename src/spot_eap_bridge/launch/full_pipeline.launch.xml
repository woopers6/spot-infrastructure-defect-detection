  <arg name="rviz" default="false"/>
  <arg name="visualization_pointcloud_topic" default="/rviz/pointcloud"/>
  <arg name="markers_topic" default="/detection_markers"/>
  <arg name="box_alpha" default="0.30"/>
  <arg name="label_height" default="0.15"/>
  <arg name="marker_lifetime_sec" default="0.50"/>
