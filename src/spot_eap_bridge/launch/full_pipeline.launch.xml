  <arg name="oak_depth_topic" default="/oak/rgb/depth"/>
  <arg name="oak_camera_info_topic" default="/oak/rgb/camera_info"/>
  <arg name="oak_depth_minimum_confidence" default="0.50"/>
  <arg name="oak_depth_bbox_padding_px" default="4"/>
  <arg name="oak_depth_default_bbox_size_m" default="0.20"/>
  <arg name="oak_localization" default="true"/>
  <arg name="oak_odom_topic" default="/oak/odom"/>
  <arg name="oak_odom_frame" default="oak_odom"/>
  <arg name="oak_odom_base_frame" default="body"/>
  <arg name="oak_odom_use_message_frame_ids" default="false"/>
