<?xml version="1.0"?>
<launch>
  <arg name="lidar_input_topic" default="/lidar/raw"/>
  <arg name="lidar_frame" default="lidar"/>
  <arg name="camera_frame" default="camera_optical_frame"/>
  <arg name="camera_index" default="0"/>
  <arg name="camera_frame_rate" default="30.0"/>
  <arg name="camera_reconnect_interval_sec" default="2.0"/>
  <arg name="publish_camera" default="true"/>
  <arg name="image_monitor" default="false"/>
  <arg name="pointcloud_monitor" default="true"/>
  <arg name="publish_extrinsics" default="false"/>
  <arg name="timestamp_mode" default="source"/>
  <arg name="max_cloud_age_sec" default="0.5"/>
  <arg name="max_future_offset_sec" default="0.05"/>
  <arg name="detector" default="false"/>
  <arg name="dataset_path"
       default="$(find-pkg-share defect_detection)/models/dataset.yaml"/>
  <arg name="model_path"
       default="$(find-pkg-share defect_detection)/models/yolov11m.engine"/>
  <arg name="image_topic" default="/ros2_image"/>
  <arg name="detections_2d_topic" default="/detections_2d"/>
  <arg name="pointcloud_topic" default="/lidar/points"/>
  <arg name="detections_3d_topic" default="/detections_3d"/>
  <arg name="fusion" default="false"/>
  <arg name="calibration_path"
       default="$(find-pkg-share defect_detection)/config/site_calibration.yaml"/>
  <arg name="visualization" default="true"/>
  <arg name="rviz" default="false"/>
  <arg name="visualization_pointcloud_topic" default="/rviz/pointcloud"/>
  <arg name="markers_topic" default="/detection_markers"/>
  <arg name="box_alpha" default="0.30"/>
  <arg name="label_height" default="0.15"/>
  <arg name="marker_lifetime_sec" default="0.50"/>
  <arg name="autonomous_navigation" default="false"/>
  <arg name="autonomous_navigation_enabled" default="false"/>
  <arg name="navigation_target_frame" default="map"/>
  <arg name="navigation_base_frame" default="base_link"/>
  <arg name="navigation_standoff_distance" default="1.50"/>
  <arg name="navigation_minimum_confidence" default="0.50"/>
  <arg name="navigation_priority_config"
       default="$(find-pkg-share defect_detection)/config/navigation_priorities.yaml"/>
  <arg name="sync_queue_size" default="30"/>
  <arg name="sync_slop_sec" default="0.10"/>
  <arg name="trimble_scan_watcher" default="false"/>
  <arg name="trimble_scan_directory" default="/tmp/trimble_scans"/>
  <arg name="trimble_scan_topic" default="/trimble/x7/scan_points"/>
  <arg name="trimble_scan_frame" default="map"/>
  <arg name="trimble_scan_max_points" default="500000"/>
  <arg name="trimble_require_scan_request" default="true"/>
  <arg name="scan_decision" default="false"/>
  <arg name="scan_required_topic" default="/digital_twin/scan_required"/>
  <arg name="scan_reason_topic" default="/digital_twin/scan_reason"/>
  <arg name="scan_confidence_threshold" default="0.65"/>
  <arg name="scan_min_detections" default="1"/>
  <arg name="scan_cooldown_sec" default="60.0"/>
  <arg name="digital_twin_map" default="false"/>
  <arg name="digital_twin_map_topic" default="/digital_twin/map"/>
  <arg name="digital_twin_map_resolution" default="0.10"/>
  <arg name="digital_twin_scan_origin_x" default="0.0"/>
  <arg name="digital_twin_scan_origin_y" default="0.0"/>
  <arg name="frontier_planner" default="false"/>
  <arg name="frontier_goal_topic" default="/digital_twin/frontier_goal"/>
  <arg name="waypoint_arrived_topic" default="/digital_twin/waypoint_arrived"/>
  <arg name="frontier_send_nav2_goals" default="false"/>
  <arg name="trimble_windows_bridge" default="false"/>
  <arg name="trimble_windows_url" default="http://127.0.0.1:8765"/>
  <arg name="trimble_reference_scan_on_start" default="true"/>
  <arg name="defect_map" default="false"/>
  <arg name="defect_map_store_path"
       default="/tmp/digital_twin_defects.yaml"/>
  <arg name="defect_map_markers_topic"
       default="/digital_twin/defect_markers"/>
  <arg name="defect_rescan_goals_topic"
       default="/digital_twin/rescan_goals"/>

  <include file="$(find-pkg-share pointcloud_bridge)/launch/pointcloud_bridge.launch.xml">
    <arg name="input_topic" value="$(var lidar_input_topic)"/>
    <arg name="output_topic" value="$(var pointcloud_topic)"/>
    <arg name="lidar_frame" value="$(var lidar_frame)"/>
    <arg name="camera_frame" value="$(var camera_frame)"/>
    <arg name="publish_extrinsics" value="$(var publish_extrinsics)"/>
    <arg name="timestamp_mode" value="$(var timestamp_mode)"/>
    <arg name="max_cloud_age_sec" value="$(var max_cloud_age_sec)"/>
    <arg name="max_future_offset_sec" value="$(var max_future_offset_sec)"/>
  </include>

  <include file="$(find-pkg-share defect_detection)/launch/defect_detection.launch.xml">
    <arg name="publish_camera" value="$(var publish_camera)"/>
    <arg name="camera_index" value="$(var camera_index)"/>
    <arg name="camera_frame" value="$(var camera_frame)"/>
    <arg name="camera_frame_rate" value="$(var camera_frame_rate)"/>
    <arg name="camera_reconnect_interval_sec"
         value="$(var camera_reconnect_interval_sec)"/>
    <arg name="image_monitor" value="$(var image_monitor)"/>
    <arg name="pointcloud_monitor" value="$(var pointcloud_monitor)"/>
    <arg name="detector" value="$(var detector)"/>
    <arg name="dataset_path" value="$(var dataset_path)"/>
    <arg name="model_path" value="$(var model_path)"/>
    <arg name="image_topic" value="$(var image_topic)"/>
    <arg name="detections_2d_topic" value="$(var detections_2d_topic)"/>
    <arg name="pointcloud_topic" value="$(var pointcloud_topic)"/>
    <arg name="detections_3d_topic" value="$(var detections_3d_topic)"/>
    <arg name="fusion" value="$(var fusion)"/>
    <arg name="calibration_path" value="$(var calibration_path)"/>
    <arg name="visualization" value="$(var visualization)"/>
    <arg name="rviz" value="$(var rviz)"/>
    <arg name="visualization_pointcloud_topic"
         value="$(var visualization_pointcloud_topic)"/>
    <arg name="markers_topic" value="$(var markers_topic)"/>
    <arg name="box_alpha" value="$(var box_alpha)"/>
    <arg name="label_height" value="$(var label_height)"/>
    <arg name="marker_lifetime_sec" value="$(var marker_lifetime_sec)"/>
    <arg name="autonomous_navigation"
         value="$(var autonomous_navigation)"/>
    <arg name="autonomous_navigation_enabled"
         value="$(var autonomous_navigation_enabled)"/>
    <arg name="navigation_target_frame"
         value="$(var navigation_target_frame)"/>
    <arg name="navigation_base_frame"
         value="$(var navigation_base_frame)"/>
    <arg name="navigation_standoff_distance"
         value="$(var navigation_standoff_distance)"/>
    <arg name="navigation_minimum_confidence"
         value="$(var navigation_minimum_confidence)"/>
    <arg name="navigation_priority_config"
         value="$(var navigation_priority_config)"/>
    <arg name="sync_queue_size" value="$(var sync_queue_size)"/>
    <arg name="sync_slop_sec" value="$(var sync_slop_sec)"/>
    <arg name="trimble_scan_watcher" value="$(var trimble_scan_watcher)"/>
    <arg name="trimble_scan_directory"
         value="$(var trimble_scan_directory)"/>
    <arg name="trimble_scan_topic" value="$(var trimble_scan_topic)"/>
    <arg name="trimble_scan_frame" value="$(var trimble_scan_frame)"/>
    <arg name="trimble_scan_max_points"
         value="$(var trimble_scan_max_points)"/>
    <arg name="trimble_require_scan_request"
         value="$(var trimble_require_scan_request)"/>
    <arg name="scan_decision" value="$(var scan_decision)"/>
    <arg name="scan_required_topic" value="$(var scan_required_topic)"/>
    <arg name="scan_reason_topic" value="$(var scan_reason_topic)"/>
    <arg name="scan_confidence_threshold"
         value="$(var scan_confidence_threshold)"/>
    <arg name="scan_min_detections" value="$(var scan_min_detections)"/>
    <arg name="scan_cooldown_sec" value="$(var scan_cooldown_sec)"/>
    <arg name="digital_twin_map" value="$(var digital_twin_map)"/>
    <arg name="digital_twin_map_topic"
         value="$(var digital_twin_map_topic)"/>
    <arg name="digital_twin_map_resolution"
         value="$(var digital_twin_map_resolution)"/>
    <arg name="digital_twin_scan_origin_x"
         value="$(var digital_twin_scan_origin_x)"/>
    <arg name="digital_twin_scan_origin_y"
         value="$(var digital_twin_scan_origin_y)"/>
    <arg name="frontier_planner" value="$(var frontier_planner)"/>
    <arg name="frontier_goal_topic" value="$(var frontier_goal_topic)"/>
    <arg name="waypoint_arrived_topic" value="$(var waypoint_arrived_topic)"/>
    <arg name="frontier_send_nav2_goals"
         value="$(var frontier_send_nav2_goals)"/>
    <arg name="trimble_windows_bridge"
         value="$(var trimble_windows_bridge)"/>
    <arg name="trimble_windows_url" value="$(var trimble_windows_url)"/>
    <arg name="trimble_reference_scan_on_start"
         value="$(var trimble_reference_scan_on_start)"/>
    <arg name="defect_map" value="$(var defect_map)"/>
    <arg name="defect_map_store_path"
         value="$(var defect_map_store_path)"/>
    <arg name="defect_map_markers_topic"
         value="$(var defect_map_markers_topic)"/>
    <arg name="defect_rescan_goals_topic"
         value="$(var defect_rescan_goals_topic)"/>
  </include>
</launch>
