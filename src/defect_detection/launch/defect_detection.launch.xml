<?xml version="1.0"?>
<launch>
  <arg name="publish_camera" default="true"
       description="Publish frames from the local camera."/>
  <arg name="camera_index" default="0"
       description="OpenCV/V4L2 camera device index."/>
  <arg name="camera_frame" default="camera_optical_frame"
       description="Frame ID attached to camera images."/>
  <arg name="camera_frame_rate" default="30.0"
       description="Requested camera publication rate."/>
  <arg name="camera_reconnect_interval_sec" default="2.0"/>
  <arg name="image_monitor" default="false"
       description="Run the simple image subscriber for topic testing."/>
  <arg name="pointcloud_monitor" default="false"
       description="Run the simple point-cloud subscriber for topic testing."/>
  <arg name="detector" default="false"
       description="Run YOLO. Requires ultralytics and models/yolov11m.engine."/>
  <arg name="dataset_path"
       default="$(find-pkg-share defect_detection)/models/dataset.yaml"/>
  <arg name="model_path"
       default="$(find-pkg-share defect_detection)/models/yolov11m.engine"/>
  <arg name="image_topic" default="/ros2_image"/>
  <arg name="detections_2d_topic" default="/detections_2d"/>
  <arg name="pointcloud_topic" default="/lidar/points"/>
  <arg name="detections_3d_topic" default="/detections_3d"/>
  <arg name="fusion" default="false"
       description="Run 2D detection and point-cloud fusion."/>
  <arg name="calibration_path"
       default="$(find-pkg-share defect_detection)/config/site_calibration.yaml"/>
  <arg name="visualization" default="true"
       description="Republish the cloud and convert 3D detections to RViz markers."/>
  <arg name="rviz" default="false"
       description="Open RViz with the point-cloud and marker displays configured."/>
  <arg name="visualization_pointcloud_topic" default="/rviz/pointcloud"/>
  <arg name="markers_topic" default="/detection_markers"/>
  <arg name="box_alpha" default="0.30"/>
  <arg name="label_height" default="0.15"/>
  <arg name="marker_lifetime_sec" default="0.50"/>
  <arg name="autonomous_navigation" default="false"
       description="Build and prioritize defect standoff goals with Nav2."/>
  <arg name="autonomous_navigation_enabled" default="false"
       description="Allow the navigator to send NavigateToPose goals."/>
  <arg name="navigation_target_frame" default="map"/>
  <arg name="navigation_base_frame" default="base_link"/>
  <arg name="navigation_standoff_distance" default="1.50"/>
  <arg name="navigation_minimum_confidence" default="0.50"/>
  <arg name="navigation_priority_config"
       default="$(find-pkg-share defect_detection)/config/navigation_priorities.yaml"/>
  <arg name="sync_queue_size" default="30"
       description="Number of detection and cloud messages retained for matching."/>
  <arg name="sync_slop_sec" default="0.10"
       description="Maximum camera/LiDAR acquisition-time difference."/>
  <arg name="trimble_scan_watcher" default="false"
       description="Watch a folder for completed Trimble X7 LAS/LAZ scans."/>
  <arg name="trimble_scan_directory" default="/tmp/trimble_scans"/>
  <arg name="trimble_scan_topic" default="/trimble/x7/scan_points"/>
  <arg name="trimble_scan_frame" default="map"/>
  <arg name="trimble_scan_max_points" default="500000"/>
  <arg name="trimble_require_scan_request" default="true"/>
  <arg name="scan_decision" default="false"
       description="Request X7 scans only for high-confidence detections."/>
  <arg name="scan_required_topic" default="/digital_twin/scan_required"/>
  <arg name="scan_reason_topic" default="/digital_twin/scan_reason"/>
  <arg name="scan_confidence_threshold" default="0.65"/>
  <arg name="scan_min_detections" default="1"/>
  <arg name="scan_cooldown_sec" default="60.0"/>
  <arg name="digital_twin_map" default="false"
       description="Convert Trimble scan points into a 2D occupancy map."/>
  <arg name="digital_twin_map_topic" default="/digital_twin/map"/>
  <arg name="digital_twin_map_resolution" default="0.10"/>
  <arg name="digital_twin_scan_origin_x" default="0.0"/>
  <arg name="digital_twin_scan_origin_y" default="0.0"/>
  <arg name="frontier_planner" default="false"
       description="Publish or send Nav2 goals at the known/unknown map edge."/>
  <arg name="frontier_goal_topic" default="/digital_twin/frontier_goal"/>
  <arg name="waypoint_arrived_topic" default="/digital_twin/waypoint_arrived"/>
  <arg name="frontier_send_nav2_goals" default="false"/>
  <arg name="frame_anchor" default="true"
       description="Anchor the digital twin map frame to the robot world frame."/>
  <arg name="robot_world_frame" default="odom"/>
  <arg name="anchor_request_topic" default="/digital_twin/anchor_request"/>
  <arg name="anchor_store_path" default="/tmp/digital_twin_anchor.yaml"/>
  <arg name="auto_anchor_on_first_scan" default="true"/>
  <arg name="infrastructure_planner" default="true"
       description="Plan generic inspection/rescan station goals."/>
  <arg name="infrastructure_goal_topic"
       default="/infrastructure/inspection_goal"/>
  <arg name="infrastructure_goal_cooldown_sec" default="20.0"/>
  <arg name="robot_goal_bridge" default="false"
       description="Send inspection goals to a robot backend."/>
  <arg name="robot_goal_backend" default="dry_run"/>
  <arg name="spot_command_url" default=""/>
  <arg name="spot_ip" default=""/>
  <arg name="spot_username" default=""/>
  <arg name="spot_password" default=""/>
  <arg name="spot_command_frame" default="odom"/>
  <arg name="spot_goal_duration_sec" default="30.0"/>
  <arg name="spot_arrival_timeout_sec" default="45.0"/>
  <arg name="spot_auto_power_on" default="false"/>
  <arg name="spot_stand_before_move" default="true"/>
  <arg name="trimble_windows_bridge" default="false"
       description="Notify the Windows Perspective bridge about scan requests and waypoint arrivals."/>
  <arg name="trimble_windows_url" default="http://127.0.0.1:8765"/>
  <arg name="trimble_reference_scan_on_start" default="true"/>
  <arg name="trimble_camera_preview" default="true"/>
  <arg name="trimble_camera_preview_rate_hz" default="2.0"/>
  <arg name="trimble_camera_preview_width" default="640"/>
  <arg name="defect_map" default="false"
       description="Persist AI defect markers for the digital twin."/>
  <arg name="defect_map_store_path"
       default="/tmp/digital_twin_defects.yaml"/>
  <arg name="defect_map_markers_topic"
       default="/digital_twin/defect_markers"/>
  <arg name="defect_rescan_goals_topic"
       default="/digital_twin/rescan_goals"/>

  <node if="$(var publish_camera)"
        pkg="defect_detection"
        exec="image_publisher"
        name="image_publisher"
        output="screen">
    <param name="camera_index" value="$(var camera_index)"/>
    <param name="frame_id" value="$(var camera_frame)"/>
    <param name="frame_rate" value="$(var camera_frame_rate)"/>
    <param name="reconnect_interval_sec"
           value="$(var camera_reconnect_interval_sec)"/>
  </node>

  <node if="$(var image_monitor)"
        pkg="defect_detection"
        exec="image_subscriber"
        name="image_subscriber"
        output="screen"/>

  <node if="$(var pointcloud_monitor)"
        pkg="defect_detection"
        exec="point_cloud_subscriber"
        name="point_cloud_subscriber"
        output="screen"/>

  <node if="$(var detector)"
        pkg="defect_detection"
        exec="yolo_detector"
        name="yolo_node"
        output="screen">
    <param name="dataset_path" value="$(var dataset_path)"/>
    <param name="model_path" value="$(var model_path)"/>
    <param name="image_topic" value="$(var image_topic)"/>
    <param name="detections_topic" value="$(var detections_2d_topic)"/>
  </node>

  <node if="$(var fusion)"
        pkg="defect_detection"
        exec="fusion_node"
        name="detection_fusion_node"
        output="screen">
    <param name="dataset_path" value="$(var dataset_path)"/>
    <param name="calibration_path" value="$(var calibration_path)"/>
    <param name="detections_2d_topic" value="$(var detections_2d_topic)"/>
    <param name="pointcloud_topic" value="$(var pointcloud_topic)"/>
    <param name="detections_3d_topic" value="$(var detections_3d_topic)"/>
    <param name="sync_queue_size" value="$(var sync_queue_size)"/>
    <param name="sync_slop_sec" value="$(var sync_slop_sec)"/>
  </node>

  <node if="$(var visualization)"
        pkg="defect_detection"
        exec="visualization_node"
        name="detection_visualization_node"
        output="screen">
    <param name="visualization_pointcloud_topic"
           value="$(var visualization_pointcloud_topic)"/>
    <param name="pointcloud_topic" value="$(var pointcloud_topic)"/>
    <param name="detections_topic" value="$(var detections_3d_topic)"/>
    <param name="markers_topic" value="$(var markers_topic)"/>
    <param name="box_alpha" value="$(var box_alpha)"/>
    <param name="label_height" value="$(var label_height)"/>
    <param name="marker_lifetime_sec" value="$(var marker_lifetime_sec)"/>
  </node>

  <node if="$(var rviz)"
        pkg="rviz2"
        exec="rviz2"
        name="rviz2"
        args="-d $(find-pkg-share defect_detection)/config/defect_visualization.rviz"
        output="screen"/>

  <node if="$(var autonomous_navigation)"
        pkg="defect_detection"
        exec="autonomous_navigator"
        name="autonomous_defect_navigator"
        output="screen">
    <param name="enabled" value="$(var autonomous_navigation_enabled)"/>
    <param name="target_frame" value="$(var navigation_target_frame)"/>
    <param name="base_frame" value="$(var navigation_base_frame)"/>
    <param name="standoff_distance"
           value="$(var navigation_standoff_distance)"/>
    <param name="minimum_confidence"
           value="$(var navigation_minimum_confidence)"/>
    <param name="priority_config_path"
           value="$(var navigation_priority_config)"/>
  </node>

  <node if="$(var trimble_scan_watcher)"
        pkg="defect_detection"
        exec="trimble_scan_watcher"
        name="trimble_scan_watcher"
        output="screen">
    <param name="scan_directory" value="$(var trimble_scan_directory)"/>
    <param name="output_topic" value="$(var trimble_scan_topic)"/>
    <param name="frame_id" value="$(var trimble_scan_frame)"/>
    <param name="max_points" value="$(var trimble_scan_max_points)"/>
    <param name="require_scan_request"
           value="$(var trimble_require_scan_request)"/>
    <param name="scan_required_topic" value="$(var scan_required_topic)"/>
  </node>

  <node if="$(var scan_decision)"
        pkg="defect_detection"
        exec="scan_decision_node"
        name="digital_twin_scan_decision"
        output="screen">
    <param name="detections_topic" value="$(var detections_2d_topic)"/>
    <param name="scan_required_topic" value="$(var scan_required_topic)"/>
    <param name="scan_reason_topic" value="$(var scan_reason_topic)"/>
    <param name="confidence_threshold"
           value="$(var scan_confidence_threshold)"/>
    <param name="min_detections" value="$(var scan_min_detections)"/>
    <param name="scan_cooldown_sec" value="$(var scan_cooldown_sec)"/>
  </node>

  <node if="$(var digital_twin_map)"
        pkg="defect_detection"
        exec="pointcloud_to_occupancy"
        name="pointcloud_to_occupancy"
        output="screen">
    <param name="pointcloud_topic" value="$(var trimble_scan_topic)"/>
    <param name="map_topic" value="$(var digital_twin_map_topic)"/>
    <param name="resolution" value="$(var digital_twin_map_resolution)"/>
    <param name="scan_origin_x" value="$(var digital_twin_scan_origin_x)"/>
    <param name="scan_origin_y" value="$(var digital_twin_scan_origin_y)"/>
  </node>

  <node if="$(var frontier_planner)"
        pkg="defect_detection"
        exec="frontier_planner"
        name="digital_twin_frontier_planner"
        output="screen">
    <param name="map_topic" value="$(var digital_twin_map_topic)"/>
    <param name="goal_topic" value="$(var frontier_goal_topic)"/>
    <param name="waypoint_arrived_topic" value="$(var waypoint_arrived_topic)"/>
    <param name="target_frame" value="$(var navigation_target_frame)"/>
    <param name="base_frame" value="$(var navigation_base_frame)"/>
    <param name="send_nav2_goals" value="$(var frontier_send_nav2_goals)"/>
  </node>

  <node if="$(var frame_anchor)"
        pkg="defect_detection"
        exec="frame_anchor_node"
        name="digital_twin_frame_anchor"
        output="screen">
    <param name="map_frame" value="$(var navigation_target_frame)"/>
    <param name="robot_world_frame" value="$(var robot_world_frame)"/>
    <param name="base_frame" value="$(var navigation_base_frame)"/>
    <param name="anchor_request_topic" value="$(var anchor_request_topic)"/>
    <param name="scan_topic" value="$(var trimble_scan_topic)"/>
    <param name="store_path" value="$(var anchor_store_path)"/>
    <param name="auto_anchor_on_first_scan"
           value="$(var auto_anchor_on_first_scan)"/>
  </node>

  <node if="$(var infrastructure_planner)"
        pkg="defect_detection"
        exec="infrastructure_planner"
        name="infrastructure_inspection_planner"
        output="screen">
    <param name="enabled" value="true"/>
    <param name="map_topic" value="$(var digital_twin_map_topic)"/>
    <param name="rescan_goals_topic" value="$(var defect_rescan_goals_topic)"/>
    <param name="goal_topic" value="$(var infrastructure_goal_topic)"/>
    <param name="target_frame" value="$(var navigation_target_frame)"/>
    <param name="base_frame" value="$(var navigation_base_frame)"/>
    <param name="standoff_distance_m"
           value="$(var navigation_standoff_distance)"/>
    <param name="goal_cooldown_sec"
           value="$(var infrastructure_goal_cooldown_sec)"/>
  </node>

  <node if="$(var robot_goal_bridge)"
        pkg="defect_detection"
        exec="robot_goal_bridge"
        name="infrastructure_robot_goal_bridge"
        output="screen">
    <param name="goal_topic" value="$(var infrastructure_goal_topic)"/>
    <param name="waypoint_arrived_topic" value="$(var waypoint_arrived_topic)"/>
    <param name="backend" value="$(var robot_goal_backend)"/>
    <param name="spot_command_url" value="$(var spot_command_url)"/>
    <param name="spot_ip" value="$(var spot_ip)"/>
    <param name="spot_username" value="$(var spot_username)"/>
    <param name="spot_password" value="$(var spot_password)"/>
    <param name="spot_command_frame" value="$(var spot_command_frame)"/>
    <param name="spot_goal_duration_sec"
           value="$(var spot_goal_duration_sec)"/>
    <param name="spot_arrival_timeout_sec"
           value="$(var spot_arrival_timeout_sec)"/>
    <param name="spot_auto_power_on" value="$(var spot_auto_power_on)"/>
    <param name="spot_stand_before_move"
           value="$(var spot_stand_before_move)"/>
  </node>

  <node if="$(var trimble_windows_bridge)"
        pkg="defect_detection"
        exec="trimble_windows_bridge"
        name="trimble_windows_bridge"
        output="screen">
    <param name="windows_url" value="$(var trimble_windows_url)"/>
    <param name="scan_required_topic" value="$(var scan_required_topic)"/>
    <param name="scan_reason_topic" value="$(var scan_reason_topic)"/>
    <param name="waypoint_arrived_topic" value="$(var waypoint_arrived_topic)"/>
    <param name="frontier_goal_topic" value="$(var frontier_goal_topic)"/>
    <param name="inspection_goal_topic" value="$(var infrastructure_goal_topic)"/>
    <param name="navigation_status_topic"
           value="/infrastructure/navigation_status"/>
    <param name="image_topic" value="$(var image_topic)"/>
    <param name="detections_topic" value="$(var detections_2d_topic)"/>
    <param name="camera_preview_enabled"
           value="$(var trimble_camera_preview)"/>
    <param name="camera_preview_rate_hz"
           value="$(var trimble_camera_preview_rate_hz)"/>
    <param name="camera_preview_width"
           value="$(var trimble_camera_preview_width)"/>
    <param name="request_reference_scan_on_start"
           value="$(var trimble_reference_scan_on_start)"/>
  </node>

  <node if="$(var defect_map)"
        pkg="defect_detection"
        exec="defect_map_node"
        name="digital_twin_defect_map"
        output="screen">
    <param name="detections_topic" value="$(var detections_3d_topic)"/>
    <param name="markers_topic" value="$(var defect_map_markers_topic)"/>
    <param name="rescan_goals_topic" value="$(var defect_rescan_goals_topic)"/>
    <param name="target_frame" value="$(var navigation_target_frame)"/>
    <param name="store_path" value="$(var defect_map_store_path)"/>
    <param name="minimum_confidence"
           value="$(var navigation_minimum_confidence)"/>
  </node>
</launch>
