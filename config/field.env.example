# Copy this file to config/field.env and fill in site-specific values.
# config/field.env is ignored by git because it contains credentials.

SPOT_IP=192.168.80.3
BOSDYN_CLIENT_USERNAME=
BOSDYN_CLIENT_PASSWORD=

CAMERA_INDEX=0
CAMERA_FRAME=camera_optical_frame
LIDAR_FRAME=lidar

# Use absolute paths so this file works from any directory.
MODEL_PATH=/home/USER/ros2_ws/src/defect_detection/models/yolov11m.engine
DATASET_PATH=/home/USER/ros2_ws/src/defect_detection/models/dataset.yaml
CALIBRATION_PATH=/home/USER/ros2_ws/src/defect_detection/config/site_calibration.yaml

ENABLE_RVIZ=true
ROS_DOMAIN_ID=42
