# Copy this file to config/field.env and fill in site-specific values.
# config/field.env is ignored by git because it contains credentials.

CAMERA_INDEX=0
PUBLISH_CAMERA=false
CAMERA_FRAME=body
IMAGE_TOPIC=/oak/rgb/image_raw
DETECTIONS_2D_TOPIC=/detections_2d
DETECTIONS_3D_TOPIC=/detections_3d

# Luxonis OAK-D Pro W style setup: wide FOV OV9782 stereo with IR illumination.
# Topic names may differ depending on the depthai_ros launch file.
OAK_DEPTH_NAVIGATION=true
OAK_DEPTH_TOPIC=/oak/rgb/depth
OAK_CAMERA_INFO_TOPIC=/oak/rgb/camera_info
OAK_DEPTH_MINIMUM_CONFIDENCE=0.50
OAK_DEPTH_BBOX_PADDING_PX=4
OAK_DEPTH_DEFAULT_BBOX_SIZE_M=0.20

# OAK localization should come from an OAK VIO/VSLAM stack such as DepthAI ROS
# odometry or RTAB-Map using OAK RGB-D. This replaces Spot odom for mission
# planning/localization.
OAK_LOCALIZATION=true
OAK_ODOM_TOPIC=/oak/odom
OAK_ODOM_FRAME=oak_odom
OAK_ODOM_BASE_FRAME=body
OAK_ODOM_USE_MESSAGE_FRAME_IDS=false
LIDAR_FRAME=lidar
LIDAR_INPUT_TOPIC=/lidar/raw
POINTCLOUD_TOPIC=/lidar/points
TRIMBLE_SCAN_DIRECTORY=/tmp/trimble_scans
TRIMBLE_SCAN_TOPIC=/trimble/x7/scan_points
TRIMBLE_WINDOWS_BRIDGE=false
TRIMBLE_WINDOWS_URL=http://192.168.1.50:8765
TRIMBLE_REFERENCE_SCAN_ON_START=true
SCAN_CONFIDENCE_THRESHOLD=0.65
SCAN_MIN_DETECTIONS=1
SCAN_COOLDOWN_SEC=60.0

# WORKSPACE_ROOT is supplied by the field scripts, so these remain portable
# when the repository is moved to another site computer.
MODEL_PATH="${WORKSPACE_ROOT}/src/defect_detection/models/yolov11m.engine"
DATASET_PATH="${WORKSPACE_ROOT}/src/defect_detection/models/dataset.yaml"
CALIBRATION_PATH="${WORKSPACE_ROOT}/src/defect_detection/config/site_calibration.yaml"

ENABLE_RVIZ=true
AUTONOMOUS_NAVIGATION=false
AUTONOMOUS_NAVIGATION_ENABLED=false
NAVIGATION_BASE_FRAME=body
NAVIGATION_PRIORITY_CONFIG="${WORKSPACE_ROOT}/src/defect_detection/config/navigation_priorities.yaml"
FRAME_ANCHOR=true
ROBOT_WORLD_FRAME=oak_odom
ANCHOR_STORE_PATH=/tmp/digital_twin_anchor.yaml
AUTO_ANCHOR_ON_FIRST_SCAN=true
INFRASTRUCTURE_PLANNER=true
INFRASTRUCTURE_GOAL_COOLDOWN_SEC=20.0

# Keep false until Spot is on the mission LAN and credentials are set.
# Backends: dry_run, nav2, http, spot_sdk.
ROBOT_GOAL_BRIDGE=false
ROBOT_GOAL_BACKEND=dry_run
SPOT_COMMAND_URL=
SPOT_IP=192.168.80.3
SPOT_USERNAME=
SPOT_PASSWORD=
SPOT_COMMAND_FRAME=body
SPOT_GOAL_DURATION_SEC=30.0
SPOT_ARRIVAL_TIMEOUT_SEC=45.0
SPOT_AUTO_POWER_ON=false
SPOT_STAND_BEFORE_MOVE=true

# Arrival is verified with the OAK-localized TF pose before another Trimble scan
# is requested.
ARRIVAL_CHECK_SOURCE=tf
ARRIVAL_BASE_FRAME=body
ARRIVAL_POSITION_TOLERANCE_M=0.35
ARRIVAL_YAW_TOLERANCE_RAD=0.45
ARRIVAL_STABLE_SEC=1.5
ROS_DOMAIN_ID=42
